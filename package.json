{
  "name": "lorcana-synergy-finder-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for Lorcana Synergy Finder",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter lorcana-synergy-finder-web dev",
    "build": "pnpm -r build",
    "build:engine": "pnpm --filter lorcana-synergy-engine build",
    "build:web": "pnpm --filter lorcana-synergy-finder-web build",
    "test": "pnpm -r test:run",
    "test:engine": "pnpm --filter lorcana-synergy-engine test:run",
    "test:web": "pnpm --filter lorcana-synergy-finder-web test:run",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "packageManager": "pnpm@9.0.0"
}
